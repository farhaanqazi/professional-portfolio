---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import VortexBackground from '../components/VortexBackground.astro';
import Interactions from '../components/Interactions.astro';
import { site } from '../data/site';

interface Props {
  title?: string;
  description?: string;
  /** Override the social card for this page (absolute or root-relative path). */
  ogImage?: string;
}

const {
  title,
  description = site.valueStatement,
  ogImage = site.ogImage,
} = Astro.props;

const pageTitle = title ? `${title} · ${site.name}` : `${site.name} · ${site.role}`;

// Absolute URLs for canonical + OG (Astro.site comes from astro.config.mjs `site`).
const canonical = new URL(Astro.url.pathname, Astro.site ?? site.url).href;
const ogImageUrl = new URL(ogImage, Astro.site ?? site.url).href;
---

<!doctype html>
<html lang="en" class="dark scroll-smooth">
  <head>
    <script is:inline>
      document.documentElement.classList.add('js');
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#050507" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Display (Orbitron) + body (Inter) faces for the sci-fi monochrome theme. -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Orbitron:wght@500;600;700;800&display=swap"
    />
    <link rel="canonical" href={canonical} />

    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content={site.name} />

    <!-- Open Graph: the shared-link preview card. Static + cacheable. -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter / X card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
  </head>
  <body class="flex min-h-screen flex-col">
    <VortexBackground />
    <div class="deco-rings" aria-hidden="true">
      <span class="ring r1"></span>
      <span class="ring r2"></span>
      <span class="ring r3"></span>
    </div>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-3 focus:z-[60] focus:rounded-md focus:bg-accent focus:px-3 focus:py-2 focus:text-sm focus:font-semibold focus:text-white"
    >
      Skip to content
    </a>
    <Header />
    <main id="main" class="flex-1">
      <slot />
    </main>
    <Footer />
    <Interactions />

    <script>
      // ── GSAP-powered scroll reveal ──────────────────────────────────────────
      // .reveal elements rise + fade in, batched so items entering together
      // stagger as a group (premium "choreographed" feel vs. one-by-one).
      // Dynamic import + try/catch: if the GSAP chunk ever fails to load, we
      // just show everything — content is never left stuck hidden.
      (async () => {
        const revealAll = () =>
          document.querySelectorAll('.reveal').forEach((el) => el.classList.add('is-visible'));

        const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (reduce) {
          revealAll();
          return;
        }

        try {
          const { gsap } = await import('gsap');
          const { ScrollTrigger } = await import('gsap/ScrollTrigger');
          gsap.registerPlugin(ScrollTrigger);

          const els = gsap.utils.toArray('.reveal');
          if (!els.length) return;

          gsap.set(els, { opacity: 0, y: 34, scale: 0.975 });

          ScrollTrigger.batch(els, {
            start: 'top 90%',
            once: true,
            onEnter: (batch) =>
              gsap.to(batch, {
                opacity: 1,
                y: 0,
                scale: 1,
                duration: 0.85,
                ease: 'power3.out',
                stagger: 0.09,
                overwrite: true,
                onComplete: () =>
                  batch.forEach((el) => el.classList.add('is-visible')),
              }),
          });

          // Re-measure once web fonts settle so trigger points stay accurate.
          if (document.fonts && document.fonts.ready) {
            document.fonts.ready.then(() => ScrollTrigger.refresh());
          }
        } catch (err) {
          revealAll();
        }
      })();
    </script>
  </body>
</html>
