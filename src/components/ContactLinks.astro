---
import Icon from './Icon.astro';
import { site } from '../data/site';

interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;

const links = [
  site.email && { href: `mailto:${site.email}`, label: 'Email', icon: 'mail' as const, external: false },
  site.github && { href: site.github, label: 'GitHub', icon: 'github' as const, external: true },
  site.linkedin && { href: site.linkedin, label: 'LinkedIn', icon: 'linkedin' as const, external: true },
].filter(Boolean) as { href: string; label: string; icon: 'mail' | 'github' | 'linkedin'; external: boolean }[];
---

<ul class={`flex flex-wrap items-center gap-x-5 gap-y-2 ${className}`}>
  {
    links.map((link) => (
      <li>
        <a
          href={link.href}
          class="group inline-flex items-center gap-2 text-sm font-medium text-slate-600 transition-colors duration-200 ease-smooth hover:text-accent dark:text-slate-400 dark:hover:text-accent-dark"
          {...(link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
        >
          <Icon name={link.icon} class="h-[1.1rem] w-[1.1rem]" />
          <span>{link.label}</span>
        </a>
      </li>
    ))
  }
</ul>
