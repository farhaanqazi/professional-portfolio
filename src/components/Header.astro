---
import { site } from '../data/site';
import ResumeLink from './ResumeLink.astro';

const nav = [
  { href: '/', label: 'Home' },
  { href: '/projects', label: 'Projects' },
  { href: '/experience', label: 'Experience' },
  { href: '/story', label: 'Story' },
  { href: '/about', label: 'About' },
];

// Normalize current path for active-state matching (strip trailing slash).
const current = Astro.url.pathname.replace(/\/+$/, '') || '/';
const isActive = (href: string) => (href === '/' ? current === '/' : current.startsWith(href));
---

<header
  class="sticky top-0 z-50 border-b border-slate-200/70 bg-white/70 backdrop-blur-xl dark:border-white/10 dark:bg-[#070711]/70"
>
  <nav class="container-content flex h-14 items-center justify-between" aria-label="Primary">
    <a
      href="/"
      class="group flex items-center gap-2 text-sm font-bold tracking-tight text-slate-900 transition-colors dark:text-slate-100"
    >
      <span class="grid h-7 w-7 place-items-center rounded-lg text-xs font-bold text-white" style="background-image:linear-gradient(135deg,var(--accent),var(--accent-2))">
        {site.name.split(' ').map((w) => w[0]).join('').slice(0, 2)}
      </span>
      <span class="transition-colors group-hover:text-accent dark:group-hover:text-accent-dark">{site.name}</span>
    </a>

    <div class="flex items-center gap-1 sm:gap-2">
      <ul class="flex items-center gap-1 sm:gap-2">
        {
          nav.map((item) => (
            <li>
              <a
                href={item.href}
                aria-current={isActive(item.href) ? 'page' : undefined}
                class:list={[
                  'rounded-md px-2.5 py-1.5 text-sm font-medium transition-colors duration-200 ease-smooth',
                  isActive(item.href)
                    ? 'text-accent dark:text-accent-dark'
                    : 'text-slate-600 hover:text-slate-900 dark:text-slate-400 dark:hover:text-slate-100',
                ]}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
      <ResumeLink variant="outline" class="ml-1 hidden !px-3.5 !py-1.5 !text-xs sm:inline-flex" />
    </div>
  </nav>
</header>
