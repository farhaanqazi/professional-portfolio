---
import { site } from '../data/site';
import ResumeLink from './ResumeLink.astro';

const nav = [
  { href: '/', label: 'Home' },
  { href: '/projects', label: 'Projects' },
  { href: '/experience', label: 'Experience' },
  { href: '/about', label: 'About' },
];

// Normalize current path for active-state matching (strip trailing slash).
const current = Astro.url.pathname.replace(/\/+$/, '') || '/';
const isActive = (href: string) => (href === '/' ? current === '/' : current.startsWith(href));
---

<header
  class="sticky top-0 z-50 border-b border-slate-200/70 bg-white/80 backdrop-blur-md dark:border-slate-800/70 dark:bg-[#0A0A0A]/80"
>
  <nav class="container-content flex h-14 items-center justify-between" aria-label="Primary">
    <a
      href="/"
      class="text-sm font-bold tracking-tight text-slate-900 transition-colors hover:text-accent dark:text-slate-100 dark:hover:text-accent-dark"
    >
      {site.name}
    </a>

    <div class="flex items-center gap-1 sm:gap-2">
      <ul class="flex items-center gap-1 sm:gap-2">
        {
          nav.map((item) => (
            <li>
              <a
                href={item.href}
                aria-current={isActive(item.href) ? 'page' : undefined}
                class:list={[
                  'rounded-md px-2.5 py-1.5 text-sm font-medium transition-colors duration-200 ease-smooth',
                  isActive(item.href)
                    ? 'text-accent dark:text-accent-dark'
                    : 'text-slate-600 hover:text-slate-900 dark:text-slate-400 dark:hover:text-slate-100',
                ]}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
      <ResumeLink variant="outline" class="ml-1 hidden px-3 py-1.5 sm:inline-flex" />
    </div>
  </nav>
</header>
