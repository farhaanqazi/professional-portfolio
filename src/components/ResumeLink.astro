---
import Icon from './Icon.astro';
import { site } from '../data/site';

interface Props {
  variant?: 'solid' | 'outline';
  class?: string;
}
const { variant = 'solid', class: className = '' } = Astro.props;

const base =
  'inline-flex items-center gap-2 rounded-lg px-4 py-2 text-sm font-semibold transition-all duration-200 ease-smooth focus-visible:ring-2';
const styles =
  variant === 'solid'
    ? 'bg-accent text-white hover:bg-accent/90 dark:bg-accent-dark dark:text-slate-900 dark:hover:bg-accent-dark/90'
    : 'border border-slate-300 text-slate-800 hover:border-accent hover:text-accent dark:border-slate-700 dark:text-slate-200 dark:hover:border-accent-dark dark:hover:text-accent-dark';
---

<a
  href={site.resumePath}
  target="_blank"
  rel="noopener noreferrer"
  class={`${base} ${styles} ${className}`}
>
  <Icon name="file" class="h-[1.1rem] w-[1.1rem]" />
  <span>Resume</span>
</a>
