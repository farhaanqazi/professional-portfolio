---
interface Props {
  eyebrow?: string;
  title: string;
  class?: string;
}
const { eyebrow, title, class: className = '' } = Astro.props;
---

<div class={className}>
  {
    eyebrow && (
      <p class="mb-1 text-xs font-semibold uppercase tracking-widest text-accent dark:text-accent-dark">
        {eyebrow}
      </p>
    )
  }
  <h2 class="text-2xl font-bold tracking-tight text-slate-900 dark:text-slate-100 sm:text-3xl">
    {title}
  </h2>
</div>
