---
interface Props {
  eyebrow?: string;
  title: string;
  class?: string;
}
const { eyebrow, title, class: className = '' } = Astro.props;
---

<div class={className}>
  {
    eyebrow && (
      <p class="eyebrow mb-2">
        {eyebrow}
      </p>
    )
  }
  <h2 class="font-display text-2xl font-bold uppercase tracking-[0.08em] text-slate-50 sm:text-3xl">
    {title}
  </h2>
</div>
