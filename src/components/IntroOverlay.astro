---
// ─────────────────────────────────────────────────────────────────────────────
// Signature intro — "raw data → insight".
// Scattered points fly in and assemble into a clean rising line chart; the name
// resolves over it; then the whole layer dissolves into the real homepage.
// On-brand (silver/monochrome, Orbitron + Inter), no audio. Plays once per
// session. JS-gated (no-JS visitors never see it and are never trapped).
// ─────────────────────────────────────────────────────────────────────────────
import { site } from '../data/site';

const letters = site.name.toUpperCase().split('');
---

<div id="intro">
  <canvas id="intro-fx" aria-hidden="true"></canvas>

  <div class="intro-content">
    <h2 class="intro-name">
      {
        letters.map((ch, i) => (
          <span class="il" style={`--d:${1700 + i * 55}ms`}>{ch === ' ' ? '  ' : ch}</span>
        ))
      }
    </h2>
    <p class="intro-role">{site.role}</p>
    <span class="intro-rule" aria-hidden="true"></span>
    <button id="intro-enter" class="intro-enter" type="button">Enter</button>
  </div>

  <button id="intro-skip" class="intro-skip" type="button">Skip intro &rarr;</button>
</div>

<style is:global>
  /* Default hidden; only the JS path shows it (no-JS users see the site directly). */
  #intro { display: none; }
  .js #intro {
    display: grid;
    place-items: center;
    position: fixed;
    inset: 0;
    z-index: 100;
    background: #050507;
    opacity: 1;
    transition: opacity 0.75s ease;
  }
  #intro.intro--out { opacity: 0; pointer-events: none; }

  html.intro-lock,
  html.intro-lock body { overflow: hidden; }

  #intro-fx { position: absolute; inset: 0; width: 100%; height: 100%; display: block; }

  .intro-content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.15rem;
    text-align: center;
    padding: 0 6vw;
    transform: translateY(-4vh);
  }
  .intro-name {
    margin: 0;
    font-family: 'Orbitron', sans-serif;
    font-weight: 400;
    color: #eef3fb;
    letter-spacing: 0.2em;
    line-height: 1;
    font-size: clamp(1.9rem, 7vw, 5.4rem);
    text-shadow: 0 0 18px rgb(180 200 255 / 0.18), 0 0 40px rgb(150 175 230 / 0.08);
    white-space: nowrap;
  }
  .il {
    display: inline-block;
    opacity: 0;
    transform: translateY(0.4em);
    animation: il-in 0.7s cubic-bezier(0.16, 1, 0.3, 1) both;
    animation-delay: var(--d, 0ms);
  }
  .intro-role {
    margin: 0;
    font-family: 'Inter', sans-serif;
    font-weight: 500;
    color: rgb(170 179 197 / 0.82);
    letter-spacing: 0.4em;
    text-transform: uppercase;
    text-indent: 0.4em;
    font-size: clamp(0.62rem, 1.4vw, 0.8rem);
    opacity: 0;
    animation: intro-fade 0.8s ease both;
    animation-delay: 2.7s;
  }
  .intro-rule {
    width: 120px;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgb(200 210 230 / 0.5), transparent);
    opacity: 0;
    animation: intro-fade 0.8s ease both;
    animation-delay: 2.9s;
  }
  .intro-enter {
    margin-top: 0.4rem;
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    font-size: 0.85rem;
    letter-spacing: 0.06em;
    color: #06060a;
    background-image: linear-gradient(180deg, #f6f8fd, #c6cedd);
    border: 1px solid rgb(255 255 255 / 0.6);
    border-radius: 9999px;
    padding: 0.72rem 2.4rem;
    cursor: pointer;
    box-shadow: 0 8px 30px -10px rgb(180 200 255 / 0.4), inset 0 1px 0 rgb(255 255 255 / 0.7);
    transition: transform 0.2s ease, box-shadow 0.2s ease, filter 0.2s ease;
    opacity: 0;
    animation: intro-fade 0.8s ease both;
    animation-delay: 3.1s;
  }
  .intro-enter:hover {
    transform: translateY(-2px);
    filter: brightness(1.06);
    box-shadow: 0 16px 44px -12px rgb(190 210 255 / 0.55), inset 0 1px 0 rgb(255 255 255 / 0.8);
  }
  .intro-skip {
    position: absolute;
    bottom: 6vh;
    left: 50%;
    transform: translateX(-50%);
    background: none;
    border: 0;
    cursor: pointer;
    color: #5f6b7d;
    font-family: 'Inter', sans-serif;
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    transition: color 0.2s ease;
    opacity: 0;
    animation: intro-fade 0.8s ease both;
    animation-delay: 3.3s;
  }
  .intro-skip:hover { color: #c6cedd; }

  @keyframes il-in {
    from { opacity: 0; transform: translateY(0.4em); filter: blur(3px); }
    to { opacity: 1; transform: none; filter: blur(0); }
  }
  @keyframes intro-fade {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .il, .intro-role, .intro-rule, .intro-enter, .intro-skip {
      animation: none !important;
      opacity: 1 !important;
      transform: none !important;
      filter: none !important;
    }
    .intro-skip { transform: translateX(-50%) !important; }
  }
</style>

<script is:inline>
  (function () {
    var intro = document.getElementById('intro');
    if (!intro) return;

    var KEY = 'fq_intro_seen';
    var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    var seen = false;
    try { seen = sessionStorage.getItem(KEY) === '1'; } catch (e) {}

    var running = false;

    function dismiss() {
      if (intro.classList.contains('intro--out')) return;
      running = false;
      intro.classList.add('intro--out');
      document.documentElement.classList.remove('intro-lock');
      try { sessionStorage.setItem(KEY, '1'); } catch (e) {}
      setTimeout(function () { intro.style.display = 'none'; }, 800);
    }

    var enter = document.getElementById('intro-enter');
    var skip = document.getElementById('intro-skip');
    if (enter) enter.addEventListener('click', dismiss);
    if (skip) skip.addEventListener('click', dismiss);
    document.addEventListener('keydown', function (e) {
      if (intro.style.display === 'none') return;
      if (e.key === 'Escape' || e.key === 'Enter') dismiss();
    });

    // Already seen this session, or reduced motion → don't run the show.
    if (seen) { intro.style.display = 'none'; return; }
    document.documentElement.classList.add('intro-lock');

    // ── Canvas: data points assembling into a rising line chart ───────────────
    var canvas = document.getElementById('intro-fx');
    var ctx = canvas && canvas.getContext('2d');
    if (!ctx) return;

    var w = 0, h = 0, dpr = 1;
    var N = 18;          // chart vertices
    var M = 40;          // ambient particles
    var pts = [];        // chart points
    var amb = [];        // ambient particles
    var t0 = performance.now();

    var easeOutCubic = function (x) { return 1 - Math.pow(1 - x, 3); };
    var lerp = function (a, b, n) { return a + (b - a) * n; };

    function layout() {
      dpr = Math.min(window.devicePixelRatio || 1, 1.6);
      w = window.innerWidth; h = window.innerHeight;
      canvas.width = Math.floor(w * dpr);
      canvas.height = Math.floor(h * dpr);
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);

      var bandW = Math.min(w * 0.66, 760);
      var x0 = (w - bandW) / 2;
      var baseY = h * 0.80;                       // chart sits low — a rising baseline beneath the CTA
      var amp = Math.min(h * 0.11, 95);

      pts = [];
      for (var i = 0; i < N; i++) {
        var n = i / (N - 1);
        var wig = 0.13 * Math.sin(n * Math.PI * 3) + 0.06 * Math.sin(n * Math.PI * 7);
        var v = Math.max(0, Math.min(1, n * 0.82 + wig + 0.09)); // overall upward trend
        pts.push({
          tx: x0 + bandW * n,
          ty: baseY - (v - 0.4) * amp,
          sx: Math.random() * w,
          sy: Math.random() * h,
          delay: 280 + i * 55,
          dur: 1050,
        });
      }
      if (!amb.length) {
        for (var j = 0; j < M; j++) {
          amb.push({ x: Math.random() * w, y: Math.random() * h, vy: -0.08 - Math.random() * 0.22, r: 0.5 + Math.random() * 1.3 });
        }
      }
      baseline = h * 0.78;
    }
    var baseline = 0;
    layout();
    window.addEventListener('resize', layout);

    function drawFrame(now, finalize) {
      var t = now - t0;
      ctx.clearRect(0, 0, w, h);

      // ambient drifting dots
      for (var a = 0; a < amb.length; a++) {
        var p = amb[a];
        if (!finalize) { p.y += p.vy; if (p.y < -4) { p.y = h + 4; p.x = Math.random() * w; } }
        ctx.beginPath();
        ctx.fillStyle = 'rgba(200,212,235,0.16)';
        ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
        ctx.fill();
      }

      // chart points + progressive line
      var line = [];
      for (var i = 0; i < N; i++) {
        var pt = pts[i];
        var pr = finalize ? 1 : Math.max(0, Math.min(1, (t - pt.delay) / pt.dur));
        var e = easeOutCubic(pr);
        var cx = lerp(pt.sx, pt.tx, e);
        var cy = lerp(pt.sy, pt.ty, e);
        if (e > 0.92) line.push([pt.tx, pt.ty]);

        // dot
        if (pr > 0) {
          ctx.beginPath();
          ctx.fillStyle = 'rgba(238,243,251,' + (0.35 + 0.5 * e).toFixed(3) + ')';
          ctx.arc(cx, cy, 2.1, 0, Math.PI * 2);
          ctx.fill();
        }
      }

      if (line.length > 1) {
        // smoothed line through the settled vertices (quadratic through midpoints)
        ctx.beginPath();
        ctx.moveTo(line[0][0], line[0][1]);
        for (var m = 1; m < line.length - 1; m++) {
          var xc = (line[m][0] + line[m + 1][0]) / 2;
          var yc = (line[m][1] + line[m + 1][1]) / 2;
          ctx.quadraticCurveTo(line[m][0], line[m][1], xc, yc);
        }
        ctx.lineTo(line[line.length - 1][0], line[line.length - 1][1]);
        ctx.strokeStyle = 'rgba(238,243,251,0.85)';
        ctx.lineWidth = 2;
        ctx.lineJoin = 'round';
        ctx.lineCap = 'round';
        ctx.shadowColor = 'rgba(190,205,240,0.35)';
        ctx.shadowBlur = 7;
        ctx.stroke();
        ctx.shadowBlur = 0;

        // pulsing "latest value" node at the leading end
        var last = line[line.length - 1];
        var pulse = finalize ? 0.5 : (0.5 + 0.5 * Math.sin(now / 320));
        ctx.beginPath();
        ctx.fillStyle = 'rgba(255,255,255,0.95)';
        ctx.arc(last[0], last[1], 3, 0, Math.PI * 2);
        ctx.fill();
        ctx.beginPath();
        ctx.strokeStyle = 'rgba(210,222,250,' + (0.5 * pulse).toFixed(3) + ')';
        ctx.lineWidth = 1.5;
        ctx.arc(last[0], last[1], 6 + 5 * pulse, 0, Math.PI * 2);
        ctx.stroke();
      }
    }

    if (reduce) {
      drawFrame(t0, true); // static final state
      return;
    }

    running = true;
    function loop() {
      if (!running) return;
      drawFrame(performance.now(), false);
      requestAnimationFrame(loop);
    }
    requestAnimationFrame(loop);
  })();
</script>
