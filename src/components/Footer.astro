---
import { site } from '../data/site';
import ContactLinks from './ContactLinks.astro';

const year = 2026; // build-time constant; bump as needed (Date is not used to keep builds reproducible).
---

<footer class="mt-20 border-t border-white/10">
  <div class="container-content flex flex-col gap-6 py-10 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <p class="font-display text-sm font-semibold uppercase tracking-[0.15em] text-slate-100">{site.name}</p>
      <p class="mt-1.5 text-sm text-slate-500">
        &copy; {year} &middot; Built with Astro &middot; WebGL
      </p>
    </div>
    <ContactLinks />
  </div>
</footer>
