---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import ContactLinks from '../components/ContactLinks.astro';
import ResumeLink from '../components/ResumeLink.astro';
import SectionHeading from '../components/SectionHeading.astro';
import Icon from '../components/Icon.astro';
import { site } from '../data/site';

const projects = await getCollection('projects');
const featured = projects
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order);

const proofPoints = [
  '8+ years preparing executive-ready reports across banking, NHS/EMEA healthcare, and operations.',
  'Power BI, Advanced Excel, and SQL — plus the automation (Python, CI/CD) most reporting analysts do not bring.',
  'Live, deployed proof — an automated dashboard generator and audit tooling, not just static screenshots.',
];

const stats = [
  { value: '8+', label: 'Years in analytics' },
  { value: '3', label: 'Industries: finance · health · ops' },
  { value: `${projects.length}`, label: 'Projects with proof' },
];
---

<BaseLayout>
  <!-- HERO -->
  <section class="container-content relative pt-20 pb-14 sm:pt-28 sm:pb-20">
    <div class="max-w-3xl">
      <p class="animate-fade glass inline-flex items-center gap-2 rounded-full px-3 py-1 text-xs font-semibold uppercase tracking-widest text-accent dark:text-accent-dark">
        <span class="h-1.5 w-1.5 animate-pulse rounded-full bg-accent dark:bg-accent-dark"></span>
        {site.role}
      </p>

      <h1 class="animate-rise mt-5 text-5xl font-bold leading-[1.05] tracking-tight text-slate-900 dark:text-slate-50 sm:text-7xl" style="animation-delay:60ms">
        {site.name.split(' ')[0]}<br />
        <span class="gradient-text">{site.name.split(' ').slice(1).join(' ')}</span>
      </h1>

      <p class="animate-rise mt-6 max-w-2xl text-lg leading-relaxed text-slate-600 dark:text-slate-300 sm:text-xl" style="animation-delay:140ms">
        {site.tagline}
      </p>
      <p class="animate-rise mt-3 text-sm font-medium text-slate-500 dark:text-slate-400" style="animation-delay:180ms">
        Based in {site.location}
      </p>

      <div class="animate-rise mt-8 flex flex-wrap items-center gap-3" style="animation-delay:220ms">
        <ResumeLink variant="solid" />
        {
          featured[0] && (
            <a href={`/projects/${featured[0].slug}`} class="btn-ghost">
              View featured work
              <Icon name="arrow-right" class="h-4 w-4" />
            </a>
          )
        }
      </div>

      <div class="animate-fade mt-8" style="animation-delay:300ms">
        <ContactLinks />
      </div>
    </div>

    <!-- Stats strip -->
    <dl class="reveal mt-14 grid grid-cols-3 gap-4 sm:max-w-xl">
      {
        stats.map((s) => (
          <div class="glass rounded-2xl px-4 py-5 text-center">
            <dt class="gradient-text text-3xl font-bold tracking-tight sm:text-4xl">{s.value}</dt>
            <dd class="mt-1 text-[0.7rem] leading-tight text-slate-500 dark:text-slate-400 sm:text-xs">
              {s.label}
            </dd>
          </div>
        ))
      }
    </dl>
  </section>

  <!-- PROOF -->
  <section class="container-content py-10">
    <div class="reveal glass max-w-prose rounded-2xl p-6 sm:p-7">
      <p class="text-xs font-semibold uppercase tracking-widest text-accent dark:text-accent-dark">
        Why consider me
      </p>
      <ul class="mt-4 space-y-3">
        {
          proofPoints.map((point) => (
            <li class="flex items-start gap-3 text-sm leading-relaxed text-slate-700 dark:text-slate-300">
              <Icon name="arrow-up-right" class="mt-0.5 h-4 w-4 flex-none text-accent dark:text-accent-dark" />
              <span>{point}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- FEATURED PROJECTS -->
  <section class="container-content py-12">
    <div class="reveal flex items-end justify-between">
      <SectionHeading eyebrow="Selected work" title="Featured projects" />
      <a href="/projects" class="hidden items-center gap-1 text-sm font-medium text-accent dark:text-accent-dark sm:inline-flex">
        All projects
        <Icon name="arrow-right" class="h-4 w-4" />
      </a>
    </div>

    {
      featured.length > 0 ? (
        <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {featured.map((project, i) => (
            <div class="reveal" style={`--reveal-delay:${Math.min(i, 6) * 70}ms`}>
              <ProjectCard project={project} />
            </div>
          ))}
        </div>
      ) : (
        <p class="mt-8 text-sm text-slate-500">No featured projects yet.</p>
      )
    }

    <a href="/projects" class="reveal mt-8 inline-flex items-center gap-1 text-sm font-medium text-accent dark:text-accent-dark sm:hidden">
      All projects
      <Icon name="arrow-right" class="h-4 w-4" />
    </a>
  </section>
</BaseLayout>
