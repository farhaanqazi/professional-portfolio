---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactLinks from '../components/ContactLinks.astro';
import ResumeLink from '../components/ResumeLink.astro';
import Icon from '../components/Icon.astro';
import IntroOverlay from '../components/IntroOverlay.astro';
import { site } from '../data/site';

// Only a count — individual projects live on their dedicated /projects page.
const projectCount = (await getCollection('projects')).length;

const capabilities = [
  { icon: 'chart' as const, title: 'Executive dashboards', desc: 'Power BI · DAX · time-series built for leadership.' },
  { icon: 'bolt' as const, title: 'Automated reporting', desc: 'Python pipelines + CI/CD on GitHub Actions & AWS.' },
  { icon: 'database' as const, title: 'Contract-governed analytics', desc: 'Validated numbers, never invented by the model.' },
];

const skills = ['Power BI · DAX', 'SQL', 'Python', 'Advanced Excel', 'CI/CD', 'AWS'];

// Optimised hero copy — punchy lead + one tight credentials line (scannable in ~8s).
const heroLead =
  'I turn scattered, multi-source data into dashboards leaders actually use — then automate the reporting cycle so it runs itself.';
const heroSub =
  '8+ years across banking, healthcare & operations · MSc Data Science · Power BI and Advanced Excel, with the rare addition of Python, SQL & CI/CD.';

// Hero name split into a non-gradient first word + gradient remainder, each
// revealed from its own overflow-hidden mask on load.
const [heroFirst, ...heroRestParts] = site.name.split(' ');
const heroRest = heroRestParts.join(' ');

const links = [
  { href: '/projects', eyebrow: 'Selected work', title: `${projectCount} projects with proof`, desc: 'Evidence-first case studies — problem, build, and measurable outcome.' },
  { href: '/experience', eyebrow: 'Track record', title: '8+ years, four sectors', desc: 'Banking, healthcare, and operations — owning the reporting cycle end to end.' },
  { href: '/story', eyebrow: 'Personal', title: 'The long way here', desc: 'From Kashmir, through banking and a master’s, to the work I couldn’t put down.' },
];

const tile = 'group tile';
const badge =
  'grid h-10 w-10 flex-none place-items-center rounded-xl border border-white/15 bg-white/[0.05] text-slate-100';
---

<BaseLayout>
  <IntroOverlay />
  <section class="container-content pt-10 pb-14 sm:pt-14">
    <div class="bento grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4 lg:[grid-auto-rows:minmax(10.5rem,auto)]">
      <!-- ── Intro / identity (anchor tile, restrained) ──────────────── -->
      <div class={`flex flex-col justify-between p-7 sm:col-span-2 lg:row-span-2 ${tile}`}>
        <div data-hero-fade>
          <div class="flex items-center gap-4">
            <div
              class="hero-rise grid h-14 w-14 flex-none place-items-center rounded-2xl border border-white/20 bg-white/[0.06] font-display text-lg font-bold gradient-text"
              style="--d:60ms;box-shadow:0 0 30px -10px rgb(180 200 255 / 0.35)"
            >
              {site.name.split(' ').map((w) => w[0]).join('').slice(0, 2)}
            </div>
            <div>
              <p class="hero-rise eyebrow text-slate-300" style="--d:160ms">
                {site.role}
              </p>
              <h1 class="mt-1 font-display text-xl font-bold uppercase tracking-[0.12em] text-slate-50 sm:text-2xl">
                <span class="word-mask"><span class="word" style="--d:240ms">{heroFirst}</span></span>{' '}<span class="word-mask"><span class="word gradient-text" style="--d:330ms">{heroRest}</span></span>
              </h1>
            </div>
          </div>
          <p class="hero-rise mt-5 max-w-xl text-left text-[1.05rem] leading-relaxed text-slate-200" style="--d:460ms">
            {heroLead}
          </p>
          <p class="hero-rise mt-3 max-w-xl text-left text-sm leading-relaxed text-slate-400" style="--d:560ms">
            {heroSub}
          </p>
        </div>
        <div class="hero-rise mt-6 flex flex-wrap items-center gap-3" style="--d:680ms">
          <ResumeLink variant="solid" class="!px-4 !py-2 !text-sm" />
          <ContactLinks />
        </div>
      </div>

      <!-- ── Stat tiles ──────────────────────────────────────────────── -->
      <div class={`reveal flex flex-col items-center justify-center p-5 text-center ${tile}`}>
        <span class="stat-bracket gradient-text font-display text-4xl font-bold tracking-tight">8+</span>
        <span class="mt-2 text-xs text-slate-400">Years cross-industry</span>
      </div>
      <a
        href="/projects"
        class={`reveal flex flex-col items-center justify-center p-5 text-center ${tile}`}
      >
        <span class="stat-bracket gradient-text font-display text-4xl font-bold tracking-tight">{projectCount}</span>
        <span class="mt-2 text-xs text-slate-400">Projects with proof</span>
      </a>

      <!-- ── Capability tiles with icon badges ───────────────────────── -->
      {
        capabilities.map((c) => (
          <div class={`reveal flex flex-col p-5 ${tile}`}>
            <span class={badge}>
              <Icon name={c.icon} class="h-5 w-5" />
            </span>
            <h2 class="mt-3 text-sm font-semibold text-slate-100">{c.title}</h2>
            <p class="mt-1 text-xs leading-relaxed text-slate-400">{c.desc}</p>
          </div>
        ))
      }

      <!-- ── Stack tile ──────────────────────────────────────────────── -->
      <div class={`reveal flex flex-col justify-center p-5 ${tile}`}>
        <p class="eyebrow">Stack</p>
        <div class="mt-3 flex flex-wrap gap-1.5">
          {
            skills.map((s) => (
              <span class="rounded-md border border-white/10 bg-white/[0.04] px-2 py-0.5 text-[0.72rem] text-slate-300">
                {s}
              </span>
            ))
          }
        </div>
      </div>

      <!-- ── Navigation CTA tiles → dedicated pages ──────────────────── -->
      {
        links.map((l) => (
          <a
            href={l.href}
            class={`reveal flex flex-col justify-between p-6 sm:col-span-2 lg:col-span-2 ${tile}`}
          >
            <div>
              <p class="eyebrow">
                {l.eyebrow}
              </p>
              <h2 class="mt-1.5 text-lg font-semibold tracking-tight text-slate-100">
                {l.title}
              </h2>
              <p class="mt-1 text-sm leading-relaxed text-slate-400">{l.desc}</p>
            </div>
            <span class="mt-5 inline-flex items-center gap-1.5 text-sm font-medium text-slate-200 transition-colors group-hover:text-white">
              Explore
              <Icon name="arrow-right" class="h-4 w-4 transition-transform duration-200 group-hover:translate-x-1" />
            </span>
          </a>
        ))
      }
    </div>
  </section>

  <style>
    .stat-bracket {
      position: relative;
      padding: 0 0.6rem;
    }
    .stat-bracket::before,
    .stat-bracket::after {
      content: '';
      position: absolute;
      top: 8%;
      height: 84%;
      width: 2px;
      background: currentColor;
      opacity: 0.4;
    }
    .stat-bracket::before { left: 0; }
    .stat-bracket::after { right: 0; }

    /* Staggered cascade as the grid scrolls/loads in (hero tile is child 1 and
       runs its own choreography, so the reveal stagger starts at child 2). */
    .bento > *:nth-child(2)  { --reveal-delay: 60ms; }
    .bento > *:nth-child(3)  { --reveal-delay: 120ms; }
    .bento > *:nth-child(4)  { --reveal-delay: 180ms; }
    .bento > *:nth-child(5)  { --reveal-delay: 240ms; }
    .bento > *:nth-child(6)  { --reveal-delay: 300ms; }
    .bento > *:nth-child(7)  { --reveal-delay: 360ms; }
    .bento > *:nth-child(8)  { --reveal-delay: 420ms; }
    .bento > *:nth-child(9)  { --reveal-delay: 480ms; }
    .bento > *:nth-child(10) { --reveal-delay: 540ms; }
  </style>
</BaseLayout>
