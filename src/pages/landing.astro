---
// ─────────────────────────────────────────────────────────────────────────────
// Cyberpunk landing gate — a faithful homage to bilalgurkansanli.com.
//
// Full-screen "cockpit" intro: black + electric cyan, wide Orbitron name framed
// by HUD divider lines, Share Tech Mono terminal text, an interactive volume
// waveform meter (with a real WebAudio test tone), and an ENTER button that
// leads into the main portfolio. Background canvas draws a faint grid, drifting
// particles, and a cursor trail. Standalone document (no site header/footer).
// ─────────────────────────────────────────────────────────────────────────────
import '../styles/global.css';
import { site } from '../data/site';

const letters = site.name.toUpperCase().split('');
// Deterministic bar heights (no randomness at build) for the volume waveform.
const bars = Array.from({ length: 34 }, (_, i) =>
  Math.round((0.32 + 0.62 * Math.abs(Math.sin(i * 0.7 + 1))) * 100)
);
const initialVolume = 70;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <script is:inline>document.documentElement.classList.add('js');</script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#020408" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{site.name} — Enter</title>
    <meta name="description" content={`${site.name} · ${site.role}`} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;500;600;700;800&family=Share+Tech+Mono&family=Inter:wght@400;500&display=swap"
    />
  </head>

  <body class="landing">
    <!-- Background FX: grid + particles + cursor trail -->
    <canvas id="fx" aria-hidden="true"></canvas>
    <div class="vignette" aria-hidden="true"></div>
    <div class="scanlines" aria-hidden="true"></div>

    <!-- Top-left HUD node -->
    <div class="node" aria-hidden="true">
      <svg viewBox="0 0 40 40" width="40" height="40">
        <circle cx="20" cy="20" r="9" fill="none" stroke="currentColor" stroke-width="1.5" />
        <circle cx="20" cy="20" r="3" fill="currentColor" />
        <path d="M20 2 V11 M20 29 V38 M2 20 H11 M29 20 H38" stroke="currentColor" stroke-width="1.5" />
      </svg>
    </div>
    <!-- Corner brackets -->
    <span class="bracket tl" aria-hidden="true"></span>
    <span class="bracket tr" aria-hidden="true"></span>
    <span class="bracket bl" aria-hidden="true"></span>
    <span class="bracket br" aria-hidden="true"></span>

    <main class="gate">
      <!-- ── Volume cluster ─────────────────────────────────────────────── -->
      <section class="vol-cluster" aria-label="Audio">
        <div class="vol">
          <button class="spk" id="spk" aria-label="Mute / unmute">
            <svg class="ico-on" viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <path d="M11 5 6 9H2v6h4l5 4z" fill="currentColor" stroke="none" />
              <path d="M16 8a5 5 0 0 1 0 8" />
              <path d="M19 5a9 9 0 0 1 0 14" />
            </svg>
            <svg class="ico-off" viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <path d="M11 5 6 9H2v6h4l5 4z" fill="currentColor" stroke="none" />
              <path d="m16 9 5 6 M21 9l-5 6" />
            </svg>
          </button>

          <div
            class="wave"
            id="wave"
            role="slider"
            tabindex="0"
            aria-label="Volume"
            aria-valuemin="0"
            aria-valuemax="100"
            aria-valuenow={initialVolume}
          >
            {bars.map((h, i) => <span class="bar" style={`--h:${h}%`} data-i={i}></span>)}
          </div>

          <span class="pct mono" id="pct">{initialVolume}%</span>
        </div>

        <p class="hint mono">Adjust volume here — or drag the waveform while testing</p>
        <button class="hud-btn mono magnetic" id="test">
          <span class="tri">▶</span> Test volume
        </button>
      </section>

      <!-- ── Identity ───────────────────────────────────────────────────── -->
      <section class="identity">
        <span class="rule" aria-hidden="true"></span>
        <h1 class="name">
          {letters.map((ch, i) => (
            <span class="ltr" style={`--d:${i * 55 + 200}ms`}>{ch === ' ' ? '  ' : ch}</span>
          ))}
        </h1>
        <p class="role mono">{site.role}</p>
        <span class="rule" aria-hidden="true"></span>
      </section>

      <!-- ── Enter ──────────────────────────────────────────────────────── -->
      <section class="enter-wrap">
        <a class="enter mono magnetic" href="/">Enter Portfolio</a>
        <a class="skip mono" href="/">Skip intro →</a>
      </section>
    </main>

    <style is:global>
      body.landing {
        margin: 0;
        height: 100vh;
        height: 100dvh;
        overflow: hidden;
        background: #020408;
        color: #cfe9f2;
        text-align: center;
        -webkit-hyphens: none;
        hyphens: none;
        cursor: default;
      }
      .landing .mono { font-family: 'Share Tech Mono', monospace; }

      /* Layers */
      #fx { position: fixed; inset: 0; z-index: 0; display: block; }
      .vignette {
        position: fixed; inset: 0; z-index: 1; pointer-events: none;
        background:
          radial-gradient(60% 50% at 50% 50%, transparent 40%, #020408 100%),
          radial-gradient(30% 30% at 8% 8%, rgb(34 226 255 / 0.10), transparent 70%),
          radial-gradient(30% 30% at 92% 8%, rgb(34 226 255 / 0.07), transparent 70%);
      }
      .scanlines {
        position: fixed; inset: 0; z-index: 2; pointer-events: none; opacity: 0.5;
        background: repeating-linear-gradient(0deg, rgb(0 0 0 / 0.25) 0 1px, transparent 1px 3px);
        mix-blend-mode: multiply;
      }

      .node { position: fixed; top: 18px; left: 20px; z-index: 4; color: #2de2ff; filter: drop-shadow(0 0 8px rgb(45 226 255 / 0.6)); }
      .bracket { position: fixed; z-index: 4; width: 26px; height: 26px; border: 1px solid rgb(45 226 255 / 0.45); }
      .bracket.tl { top: 16px; left: 16px; border-right: 0; border-bottom: 0; }
      .bracket.tr { top: 16px; right: 16px; border-left: 0; border-bottom: 0; }
      .bracket.bl { bottom: 16px; left: 16px; border-right: 0; border-top: 0; }
      .bracket.br { bottom: 16px; right: 16px; border-left: 0; border-top: 0; }

      /* Layout */
      .gate {
        position: relative; z-index: 3;
        height: 100vh; height: 100dvh;
        display: grid; grid-template-rows: 1fr auto 1fr;
        align-items: center; justify-items: center;
        padding: 5vh 6vw; box-sizing: border-box;
      }

      /* Volume cluster */
      .vol-cluster { align-self: start; display: flex; flex-direction: column; align-items: center; gap: 14px; }
      .vol { display: flex; align-items: center; gap: 16px; }
      .spk {
        background: none; border: 0; color: #cfe9f2; cursor: pointer; padding: 4px;
        display: grid; place-items: center; transition: color 0.2s, filter 0.2s;
      }
      .spk:hover { color: #2de2ff; filter: drop-shadow(0 0 6px rgb(45 226 255 / 0.7)); }
      .spk .ico-off { display: none; }
      .spk.muted .ico-on { display: none; }
      .spk.muted .ico-off { display: block; color: #5b6b72; }

      .wave { display: flex; align-items: center; gap: 3px; height: 34px; cursor: ew-resize; touch-action: none; }
      .wave:focus-visible { outline: 1px solid rgb(45 226 255 / 0.6); outline-offset: 6px; }
      .bar {
        width: 4px; height: var(--h, 40%); border-radius: 1px;
        background: rgb(120 150 160 / 0.35);
        transition: background 0.12s ease, box-shadow 0.12s ease, transform 0.12s ease;
      }
      .bar.on { background: #2de2ff; box-shadow: 0 0 6px rgb(45 226 255 / 0.7); }
      .bar.test { transform: scaleY(1.5); }
      .pct { color: #2de2ff; font-size: 0.9rem; letter-spacing: 0.08em; min-width: 3ch; text-align: left; }

      .hint { color: #6f8088; font-size: 0.82rem; letter-spacing: 0.18em; }
      .hud-btn {
        background: transparent; color: #bfe9f2; cursor: pointer;
        border: 1px solid rgb(45 226 255 / 0.45);
        padding: 9px 18px; font-size: 0.8rem; letter-spacing: 0.2em; text-transform: uppercase;
        transition: background 0.2s, color 0.2s, box-shadow 0.2s, border-color 0.2s;
        will-change: transform;
      }
      .hud-btn .tri { color: #2de2ff; font-size: 0.7em; }
      .hud-btn:hover { color: #02141a; background: #2de2ff; border-color: #2de2ff; box-shadow: 0 0 24px -4px rgb(45 226 255 / 0.6); }
      .hud-btn:hover .tri { color: #02141a; }

      /* Identity */
      .identity { display: flex; flex-direction: column; align-items: center; gap: 18px; }
      .rule { width: 170px; height: 1px; background: linear-gradient(90deg, transparent, rgb(45 226 255 / 0.7), transparent); }
      .name {
        margin: 0; font-family: 'Orbitron', sans-serif; font-weight: 400;
        color: #dbf3fb; letter-spacing: 0.2em;
        font-size: clamp(1.9rem, 7.2vw, 5.6rem); line-height: 1;
        /* Tight cyan halo only — no white core (that's what washed the edges out). */
        text-shadow: 0 0 14px rgb(45 226 255 / 0.22), 0 0 34px rgb(45 226 255 / 0.12);
        white-space: nowrap;
      }
      .ltr {
        display: inline-block; opacity: 0; transform: translateY(0.35em);
        animation: ltr-in 0.7s cubic-bezier(0.16, 1, 0.3, 1) both; animation-delay: var(--d, 0ms);
      }
      .role {
        margin: 0; color: rgb(45 226 255 / 0.62); font-size: clamp(0.68rem, 1.5vw, 0.95rem);
        letter-spacing: 0.42em; text-transform: uppercase; text-indent: 0.42em;
        text-shadow: 0 0 10px rgb(45 226 255 / 0.18);
        opacity: 0; animation: fade-in 0.9s ease both; animation-delay: 1.4s;
      }

      /* Enter */
      .enter-wrap { align-self: end; display: flex; flex-direction: column; align-items: center; gap: 16px; opacity: 0; animation: fade-in 1s ease both; animation-delay: 1.8s; }
      .enter {
        font-family: 'Share Tech Mono', monospace; text-decoration: none;
        color: #d7f6fd; letter-spacing: 0.34em; text-transform: uppercase; text-indent: 0.34em;
        font-size: 0.95rem; padding: 16px 42px; border: 1px solid rgb(45 226 255 / 0.5);
        position: relative; will-change: transform;
        transition: background 0.25s, color 0.25s, box-shadow 0.25s, border-color 0.25s;
      }
      .enter:hover { color: #02141a; background: #2de2ff; border-color: #2de2ff; box-shadow: 0 0 40px -6px rgb(45 226 255 / 0.7); }
      .skip { color: #5d6e75; text-decoration: none; font-size: 0.72rem; letter-spacing: 0.22em; text-transform: uppercase; transition: color 0.2s; }
      .skip:hover { color: #2de2ff; }

      @keyframes ltr-in { from { opacity: 0; transform: translateY(0.3em); filter: blur(3px); } to { opacity: 1; transform: none; filter: blur(0); } }
      @keyframes fade-in { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: none; } }

      @media (prefers-reduced-motion: reduce) {
        .ltr, .role, .enter-wrap { animation: none !important; opacity: 1 !important; transform: none !important; filter: none !important; }
      }
    </style>

    <script>
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const fine = window.matchMedia('(pointer: fine)').matches;

      // ── Background FX: grid + particles + cursor trail ──────────────────────
      const canvas = document.getElementById('fx') as HTMLCanvasElement;
      const ctx = canvas.getContext('2d');
      if (ctx) {
        let w = 0, h = 0, dpr = 1;
        const CYAN = '45, 226, 255';
        type P = { x: number; y: number; vx: number; vy: number; r: number };
        let parts: P[] = [];
        const trail: { x: number; y: number; life: number }[] = [];
        let mx = -999, my = -999;

        const seed = (() => { let s = 1337; return () => (s = (s * 16807) % 2147483647) / 2147483647; })();
        const resize = () => {
          dpr = Math.min(window.devicePixelRatio || 1, 1.5);
          w = window.innerWidth; h = window.innerHeight;
          canvas.width = Math.floor(w * dpr); canvas.height = Math.floor(h * dpr);
          canvas.style.width = w + 'px'; canvas.style.height = h + 'px';
          ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
          const count = Math.round((w * h) / 26000);
          parts = Array.from({ length: count }, () => ({
            x: seed() * w, y: seed() * h,
            vx: (seed() - 0.5) * 0.25, vy: -0.1 - seed() * 0.3,
            r: 0.6 + seed() * 1.4,
          }));
        };
        window.addEventListener('resize', resize);
        resize();

        if (fine && !reduce) {
          window.addEventListener('pointermove', (e) => {
            mx = e.clientX; my = e.clientY;
            trail.push({ x: e.clientX, y: e.clientY, life: 1 });
            if (trail.length > 40) trail.shift();
          }, { passive: true });
        }

        const grid = (gap: number) => {
          ctx.strokeStyle = `rgba(${CYAN}, 0.045)`;
          ctx.lineWidth = 1;
          const ox = (mx > 0 ? (mx - w / 2) : 0) * 0.01;
          const oy = (my > 0 ? (my - h / 2) : 0) * 0.01;
          ctx.beginPath();
          for (let x = (ox % gap); x < w; x += gap) { ctx.moveTo(x, 0); ctx.lineTo(x, h); }
          for (let y = (oy % gap); y < h; y += gap) { ctx.moveTo(0, y); ctx.lineTo(w, y); }
          ctx.stroke();
        };

        const draw = () => {
          ctx.clearRect(0, 0, w, h);
          grid(46);

          // particles
          for (const p of parts) {
            p.x += p.vx; p.y += p.vy;
            if (p.y < -5) { p.y = h + 5; p.x = seed() * w; }
            if (p.x < -5) p.x = w + 5; else if (p.x > w + 5) p.x = -5;
            ctx.beginPath();
            ctx.fillStyle = `rgba(${CYAN}, 0.5)`;
            ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
            ctx.fill();
          }

          // cursor trail
          for (let i = 0; i < trail.length; i++) {
            const t = trail[i]; t.life -= 0.03;
            if (t.life <= 0) continue;
            ctx.beginPath();
            ctx.fillStyle = `rgba(${CYAN}, ${t.life * 0.5})`;
            ctx.arc(t.x, t.y, t.life * 9, 0, Math.PI * 2);
            ctx.fill();
          }
          while (trail.length && trail[0].life <= 0) trail.shift();

          if (!reduce) requestAnimationFrame(draw);
        };
        draw();
      }

      // ── Volume waveform meter ───────────────────────────────────────────────
      const wave = document.getElementById('wave')!;
      const pct = document.getElementById('pct')!;
      const spk = document.getElementById('spk')!;
      const test = document.getElementById('test')!;
      const barEls = Array.from(wave.querySelectorAll<HTMLElement>('.bar'));
      let volume = 70;
      let muted = false;

      const paint = () => {
        const shown = muted ? 0 : volume;
        const n = barEls.length;
        barEls.forEach((b, i) => b.classList.toggle('on', (i / n) * 100 < shown));
        pct.textContent = `${Math.round(shown)}%`;
        wave.setAttribute('aria-valuenow', String(Math.round(volume)));
      };
      paint();

      const setFromX = (clientX: number) => {
        const r = wave.getBoundingClientRect();
        volume = Math.max(0, Math.min(100, ((clientX - r.left) / r.width) * 100));
        muted = false; spk.classList.remove('muted');
        paint();
      };
      let dragging = false;
      wave.addEventListener('pointerdown', (e) => { dragging = true; (e.target as Element).setPointerCapture?.((e as PointerEvent).pointerId); setFromX((e as PointerEvent).clientX); });
      wave.addEventListener('pointermove', (e) => { if (dragging) setFromX((e as PointerEvent).clientX); });
      window.addEventListener('pointerup', () => { dragging = false; });
      wave.addEventListener('keydown', (e) => {
        const k = (e as KeyboardEvent).key;
        if (k === 'ArrowLeft' || k === 'ArrowDown') { volume = Math.max(0, volume - 5); paint(); }
        if (k === 'ArrowRight' || k === 'ArrowUp') { volume = Math.min(100, volume + 5); paint(); }
      });
      spk.addEventListener('click', () => { muted = !muted; spk.classList.toggle('muted', muted); paint(); });

      // ── WebAudio test tone (real beep at the chosen volume) ─────────────────
      let actx: AudioContext | null = null;
      test.addEventListener('click', () => {
        try {
          actx = actx || new (window.AudioContext || (window as any).webkitAudioContext)();
          if (actx.state === 'suspended') actx.resume();
          const t0 = actx.currentTime;
          const osc = actx.createOscillator();
          const gain = actx.createGain();
          const vol = (muted ? 0 : volume / 100) * 0.18; // keep it gentle
          osc.type = 'sine';
          osc.frequency.setValueAtTime(523.25, t0);
          osc.frequency.exponentialRampToValueAtTime(880, t0 + 0.35);
          gain.gain.setValueAtTime(0.0001, t0);
          gain.gain.exponentialRampToValueAtTime(Math.max(0.0001, vol), t0 + 0.04);
          gain.gain.exponentialRampToValueAtTime(0.0001, t0 + 0.5);
          osc.connect(gain).connect(actx.destination);
          osc.start(t0); osc.stop(t0 + 0.52);
        } catch { /* audio unavailable — ignore */ }

        // visual "testing" pulse across the bars
        if (!reduce) {
          barEls.forEach((b, i) => {
            setTimeout(() => {
              b.classList.add('test');
              setTimeout(() => b.classList.remove('test'), 140);
            }, i * 18);
          });
        }
      });

      // ── Magnetic buttons (fine pointers, motion-on only) ────────────────────
      if (fine && !reduce) {
        const lerp = (a: number, b: number, n: number) => a + (b - a) * n;
        const items = Array.from(document.querySelectorAll<HTMLElement>('.magnetic')).map((el) => ({ el, cx: 0, cy: 0, tx: 0, ty: 0 }));
        items.forEach((m) => {
          m.el.addEventListener('pointermove', (e) => {
            const r = m.el.getBoundingClientRect();
            m.tx = ((e as PointerEvent).clientX - (r.left + r.width / 2)) * 0.45;
            m.ty = ((e as PointerEvent).clientY - (r.top + r.height / 2)) * 0.45;
          });
          m.el.addEventListener('pointerleave', () => { m.tx = 0; m.ty = 0; });
        });
        const tick = () => {
          for (const m of items) {
            m.cx = lerp(m.cx, m.tx, 0.2); m.cy = lerp(m.cy, m.ty, 0.2);
            const rest = Math.abs(m.cx) < 0.05 && Math.abs(m.cy) < 0.05 && m.tx === 0 && m.ty === 0;
            m.el.style.transform = rest ? '' : `translate3d(${m.cx.toFixed(2)}px, ${m.cy.toFixed(2)}px, 0)`;
          }
          requestAnimationFrame(tick);
        };
        requestAnimationFrame(tick);
      }
    </script>
  </body>
</html>
