---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
---

<BaseLayout title="Page not found" description="This page does not exist.">
  <section class="container-content flex flex-col items-center justify-center py-24 text-center">
    <p class="text-5xl font-bold tracking-tight text-accent dark:text-accent-dark">404</p>
    <h1 class="mt-4 text-2xl font-bold tracking-tight text-slate-900 dark:text-slate-100">
      Page not found
    </h1>
    <p class="mt-2 max-w-sm text-slate-600 dark:text-slate-400">
      The page you are looking for moved or never existed.
    </p>
    <a
      href="/"
      class="mt-6 inline-flex items-center gap-1.5 rounded-lg bg-accent px-4 py-2 text-sm font-semibold text-white transition-colors hover:bg-accent/90 dark:bg-accent-dark dark:text-slate-900 dark:hover:bg-accent-dark/90"
    >
      Back home
      <Icon name="arrow-right" class="h-4 w-4" />
    </a>
  </section>
</BaseLayout>
