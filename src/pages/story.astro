---
import BaseLayout from '../layouts/BaseLayout.astro';

const openingTyped = 'Growing up in Kashmir, my world was defined by its limits as much as by its landscape.';
const openingRest =
  ' School meant memorising facts under pressure, not asking questions about them. There was no science fair, no debate club, no moment where someone sat across from me and said, “you could do something with this.” Mathematics was the one exception — not because I was told to value it, but because it was the only place where I could see that I was genuinely good at something without needing to be told so.';

// All-audience version: no PhD / academic-application framing, full journey intact.
// Dates aligned to the CV (the timeline source of truth).
const paras = [
  'My BEng in Civil Engineering in 2012 was a credential, not a calling. The years immediately after were spent trying to find professional footing — eventually landing a role in construction in 2014, which ended in 2015. After that I went back to Kashmir, and this is where the story becomes difficult to explain to someone who has not felt that particular pull. There is an attachment to that place that does not respond to career logic. I wanted to build a professional life within a region where the private sector is almost entirely absent and stable employment runs almost exclusively through government examinations. So I prepared for them, sat them, and in March 2017 I joined J&K Bank.',
  'I spent five years there. I worked with financial data — risk signals, transactional patterns, compliance reporting — and I noticed, fairly early, that the gap between what the data actually contained and what the organisation believed it was telling them was significant and consequential. I started building things to close that gap. Nothing dramatic. Cleaner models, more honest reports, analyses that asked a slightly different question than the one I had been given. That habit of looking at the existing tool and finding it insufficient — that started there, in a government bank in Kashmir, long before I had any language for it.',
  'In 2022 I made a decision that felt enormous at the time: I left banking and enrolled in an MSc in Data Science at Heriot-Watt University in Edinburgh. The move was not just geographical. It was the first time I deliberately chose difficulty over stability, the first time I bet on the instinct rather than suppressing it.',
  'What happened at Heriot-Watt I was not prepared for. Partway through the programme, before I had even reached my dissertation, a professor pulled me aside. He had watched how I worked through problems, and he told me — plainly — that I was capable of far more than I was attempting. I did not act on it. Not because I was uninterested, but because I genuinely did not understand what he was seeing in me, or whether I was the kind of person built for it. I let the moment pass without grasping what I was letting go of.',
  'The dissertation showed me. I was working on a machine learning approach to Parkinson’s disease diagnosis, and something happened during those months that had not happened to me before in any academic or professional setting. I was not completing tasks. I was thinking inside a problem — running into walls, finding my way around them, changing direction when the data said to, building something that had not existed before I started. I did not want to stop. When I submitted, the report was selected by the school as an exemplar and placed on the university portal for future students. Peers came to me during their own work — not because I invited them, but because the work had earned it. That professor’s earlier words, in retrospect, began to make a different kind of sense.',
  'After graduating in December 2023 I remained in the UK, working across healthcare analytics and operational data roles — the NHS, and briefly other organisations. The work was useful and I learned from it. But the feeling that had started during the dissertation did not leave. It sharpened, with each role — each time I found the existing tools inadequate and built something closer to what was needed. The audit system. The clinical pipeline. The dashboard engine. None of these were asked for. They were the product of a consistent inability to leave a visible gap unfilled.',
  'I am 36. I understand what that number can look like, and I would rather address it plainly than pretend it is not there. The years between my degree and now are not a story of delay. They are the story of someone who grew up where ambition had few outlets, who spent years building real domain depth and technical capability in applied settings, and who only gradually came to understand what he was actually built to do. I arrive now with everything I did not have at the start: the domain knowledge, the technical grounding, the instinct for the right problem, and finally the self-knowledge to recognise it.',
  'I am not chasing the next rung on a ladder. I want work that lets me keep doing what I have been doing for years, in whatever form was available — closing the distance between what the data actually says and what people believe it says, and building the thing that is missing. I want to do it properly, and at the level it deserves.',
];

const pullQuotes: Record<number, string> = {
  1: 'I was not completing tasks. I was thinking inside a problem.',
  5: 'The product of a consistent inability to leave a visible gap unfilled.',
};
---

<BaseLayout
  title="Story"
  description="The long way here — from Kashmir, through banking and a master's, to the problem I couldn't put down."
>
  <article class="container-content py-16 sm:py-24">
    <header class="mx-auto max-w-prose text-center">
      <p class="text-xs font-semibold uppercase tracking-[0.3em] text-accent dark:text-accent-dark">
        Personal
      </p>
      <h1 class="mt-4 font-serif text-4xl font-semibold leading-tight tracking-tight text-slate-900 dark:text-slate-50 sm:text-5xl">
        <span id="title-typed">The long way here</span><span id="title-cursor" class="typed-cursor title-cursor" aria-hidden="true"></span>
      </h1>
      <div class="mx-auto mt-6 h-px w-16 bg-gradient-to-r from-transparent via-accent to-transparent dark:via-accent-dark"></div>
    </header>

    <div class="mx-auto mt-12 max-w-prose font-serif text-[1.15rem] leading-[1.85] text-slate-700 dark:text-slate-300">
      <!--
        Opening paragraph is fully server-rendered (correct with no JS and with reduced motion).
        When motion is allowed, the script hides #opening-rest with display:none (no reserved gap),
        retypes #typed, then fades the rest back in.
      -->
      <p class="text-[1.3rem] leading-[1.7] text-slate-900 dark:text-slate-100">
        <span id="typed">{openingTyped}</span><span id="cursor" class="typed-cursor" aria-hidden="true"></span><span id="opening-rest">{openingRest}</span>
      </p>

      {
        paras.map((p, i) => (
          <>
            <p class="reveal mt-7">{p}</p>
            {pullQuotes[i] && (
              <blockquote class="reveal my-10 border-l-2 border-accent/60 pl-6 text-[1.35rem] font-medium italic leading-snug text-slate-900 dark:border-accent-dark/60 dark:text-slate-100">
                {pullQuotes[i]}
              </blockquote>
            )}
          </>
        ))
      }

      <div class="reveal mt-14 border-t border-slate-200 pt-8 text-center dark:border-white/10">
        <a href="/projects" class="btn-ghost">The work this produced &rarr;</a>
      </div>
    </div>
  </article>

  <style>
    /* Cursor only shows while the typing effect is active (added by JS). */
    .typed-cursor {
      display: none;
      width: 3px;
      height: 1.05em;
      margin-left: 1px;
      transform: translateY(2px);
      background: var(--accent);
    }
    .typed-cursor.active {
      display: inline-block;
      animation: blink 1s step-end infinite;
    }
    /* Title cursor is taller to match the big serif heading. */
    .title-cursor {
      width: 4px;
      background: var(--accent);
    }
    @keyframes blink { 50% { opacity: 0; } }
  </style>

  <script is:inline>
    (function () {
      // Type `text` into `el`, blinking `cursor`, then call `done()`.
      function typeInto(el, cursor, text, opts, done) {
        el.textContent = '';
        if (cursor) cursor.classList.add('active');
        var i = 0;
        function tick() {
          i++;
          el.textContent = text.slice(0, i);
          if (i < text.length) {
            setTimeout(tick, opts.min + Math.random() * opts.rand);
          } else if (done) {
            done();
          }
        }
        setTimeout(tick, opts.start || 0);
      }

      function run() {
        var title = document.getElementById('title-typed');
        var titleCursor = document.getElementById('title-cursor');

        // The title and the full opening paragraph are server-rendered, so no-JS and
        // reduced-motion users see everything as sent. Only the TITLE types; the body
        // copy stays static.
        var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (reduce) return;

        var titleText = title ? (title.textContent || '') : '';
        if (!title || !titleText) return;

        typeInto(title, titleCursor, titleText, { min: 55, rand: 70, start: 300 }, function () {
          if (titleCursor) setTimeout(function () { titleCursor.classList.remove('active'); }, 450);
        });
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', run);
      } else {
        run();
      }
    })();
  </script>
</BaseLayout>
